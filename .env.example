# Rest Point Production Environment Variables
# Copy this file to .env and update with your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_ROOT_PASSWORD=RestPoint2024!
DB_PASSWORD=RestPointUser2024

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_PASSWORD=RestPointRedis2024

# ============================================
# RABBITMQ CONFIGURATION
# ============================================
RABBITMQ_USER=restpoint
RABBITMQ_PASSWORD=RestPointRabbit2024

# ============================================
# JWT SECRET (CHANGE THIS IN PRODUCTION!)
# ============================================
JWT_SECRET=RestPointJWTSecret2024ChangeMe

# ============================================
# DEFAULT ADMIN CREDENTIALS
# ============================================
DEFAULT_ADMIN_EMAIL=infowelttallis@gmail.com
DEFAULT_ADMIN_PASSWORD=40045355

# ============================================
# MPESA CONFIGURATION (Optional)
# ============================================
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# ============================================
# SMTP CONFIGURATION (Optional - for emails)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=production
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://app.restpoint.co.ke