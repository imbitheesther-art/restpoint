{
  "name": "@montezuma/restpoint",
  "version": "1.0.0",
  "private": true,
  "description": "Restpoint — Modern Kenyan Mortuary Management SaaS Platform",
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "workspaces": [
    "packages/*",
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n gateway,services -c blue,green \"npm run dev --workspace=restpoint-gateway\" \"npm run dev --workspaces\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "setup": "npm install",
    "bootstrap": "npm install",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=100",
    "docker:rebuild": "docker compose down && docker compose build --no-cache && docker compose up -d",
    "provision-worker": "ts-node services/tenant-service/scripts/provision-worker.ts"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/validator": "^13.15.10",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "bull": "^3.29.3",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "csurf": "^1.11.0",
    "express-rate-limit": "^8.6.0",
    "express-session": "^1.19.0",
    "helmet": "^8.3.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.3.0",
    "mysql2": "^3.22.6",
    "path-to-regexp": "^8.4.2",
    "pdfkit": "^0.19.1",
    "pino-loki": "^3.0.0",
    "prop-types": "^15.8.1",
    "puppeteer": "^25.3.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/pino": "^7.0.4",
    "concurrently": "^8.2.2",
    "pino": "^10.3.1",
    "typescript": "^5.8.2",
    "vite-plugin-compression2": "^2.5.3"
  }
}
