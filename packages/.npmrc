# Registry configuration for @montezuma scoped packages
# Using public npm registry for local development
@montezuma:registry=https://registry.npmjs.org/

# Always-auth is required for private registries (commented out for public registry)
# //npm.your-company.com/:_authToken=${NPM_TOKEN}

# For Verdaccio (local development), use:
# @montezuma:registry=http://localhost:4873
# //localhost:4873/:_authToken=${NPM_TOKEN}
