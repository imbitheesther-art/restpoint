# RestPoint Docker Deployment Configuration

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
APP_ENV=production

# ============================================
# DATABASE (MariaDB) - Local Docker container
# ============================================
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=restpoint_main
DB_USER=restpoint_user
DB_PASSWORD=RestPointUser2024
DB_ROOT_PASSWORD=RestPoint2024!

# ============================================
# CACHE (Redis) - Local Docker container
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=RestPointRedis2024

# ============================================
# MESSAGE QUEUE (RabbitMQ) - Local Docker container
# ============================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=restpoint
RABBITMQ_PASSWORD=RestPointRabbit2024

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=RestPointJWTSecret2024ChangeMe!SuperSecureInProduction
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=RestPointRefreshTokenSecret2024!ChangeMe
REFRESH_TOKEN_EXPIRY=7d

# Internal service-to-service authentication
INTERNAL_SERVICE_SECRET=siasahub_internal_secret_2026_change_in_production

# ============================================
# API GATEWAY CONFIGURATION
# ============================================
API_GATEWAY_URL=http://api-gateway:5000

# ============================================
# DEFAULT ADMIN CREDENTIALS
# ============================================
DEFAULT_ADMIN_EMAIL=infowelttallis@gmail.com
DEFAULT_ADMIN_PASSWORD=40045355

# ============================================
# M-PESA CONFIGURATION
# ============================================
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_PASSKEY=your_mpesa_passkey_here
MPESA_SHORTCODE=your_shortcode_here

# ============================================
# EMAIL/SMTP CONFIGURATION
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@restpoint.local
SMTP_SECURE=false

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# FRONTEND CONFIGURATION
# ============================================
REACT_APP_API_BASE_URL=http://localhost:8000/api
REACT_APP_SOCKETIO_URL=http://localhost:3000
REACT_APP_ENV=production

# ============================================
# EXTERNAL SERVICE PORTS (External)
# ============================================
API_GATEWAY_EXTERNAL_PORT=5000
AUTH_SERVICE_EXTERNAL_PORT=5001
TENANT_SERVICE_EXTERNAL_PORT=5002
DECEASED_SERVICE_EXTERNAL_PORT=5003
MARKETPLACE_SERVICE_EXTERNAL_PORT=5004
INVOICE_SERVICE_EXTERNAL_PORT=5005
COFFIN_SERVICE_EXTERNAL_PORT=5006
DOCUMENTS_SERVICE_EXTERNAL_PORT=5007
EDOCUMENTS_SERVICE_EXTERNAL_PORT=8116
ANALYTICS_SERVICE_EXTERNAL_PORT=5009
CALENDAR_SERVICE_EXTERNAL_PORT=5010
MPESA_SERVICE_EXTERNAL_PORT=5011
NOTIFICATION_SERVICE_EXTERNAL_PORT=5111
QRCODE_SERVICE_EXTERNAL_PORT=5012
SOCKETIO_SERVICE_EXTERNAL_PORT=5013
VISITORS_SERVICE_EXTERNAL_PORT=5014
BODYCHECKOUT_SERVICE_EXTERNAL_PORT=5015
EXTRA_SERVICES_EXTERNAL_PORT=5016
UPDATES_SERVICE_EXTERNAL_PORT=5017
CALL_SERVICE_EXTERNAL_PORT=5018
PORTAL_SERVICE_EXTERNAL_PORT=5019
BILLING_SERVICE_EXTERNAL_PORT=5020
CHEMICAL_SERVICE_EXTERNAL_PORT=5105
EMBALMING_SERVICE_EXTERNAL_PORT=5105

# Database/Message Queue Ports
MARIADB_EXTERNAL_PORT=3306
REDIS_EXTERNAL_PORT=6379
RABBITMQ_EXTERNAL_PORT=5672
