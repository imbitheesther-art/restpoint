# api-gateway Configuration
NODE_ENV=production
PORT=5000
SERVICE_NAME=api-gateway
INTERNAL_SERVICE_SECRET=RestPointInternalSecret2024

# Database
DB_HOST=restpoint_mariadb
DB_PORT=3306
DB_NAME=restpoint_main
DB_USER=restpoint_user
DB_PASSWORD=RestPointUser2024

# Redis Cache
REDIS_HOST=restpoint_redis
REDIS_PORT=6379
# REDIS_PASSWORD=RestPointRedis2024

# RabbitMQ
RABBITMQ_HOST=restpoint_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=restpoint
RABBITMQ_PASSWORD=RestPointRabbit2024

# JWT/Security
JWT_SECRET=RestPointJWTSecret2024ChangeMe!SuperSecureInProduction

# Service-specific Configuration
RATE_LIMIT_WINDOW_MS=9000
RATE_LIMIT_MAX_REQUESTS=100
SERVICE_TIMEOUT=30000

# CORS Configuration - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5174

