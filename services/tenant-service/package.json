{
  "name": "@restpoint/tenant-service",
  "version": "1.0.0",
  "description": "RestPoint tenant-service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch . --ext ts --exec \"npx ts-node server.ts\"",
    "dev:watch": "nodemon --watch . --ext ts --exec \"npx ts-node server.ts\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:dev": "npx ts-node server.ts",
    "lint": "echo 'Tenant lint OK'",
    "lint:fix": "echo 'Tenant lint fix OK'",
    "test": "echo 'No tests yet'",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "migrate": "npx ts-node scripts/run-tenant-migrations.ts",
    "migrate:all": "npx ts-node scripts/run-tenant-migrations.ts",
    "migrate:tenant": "npx ts-node scripts/run-tenant-migrations.ts --tenant"
  },
  "nodemonConfig": {
    "watch": [
      "."
    ],
    "ext": "ts",
    "ignore": [
      "dist/*",
      "node_modules/*",
      "*.test.ts",
      "*.spec.ts"
    ],
    "execMap": {
      "ts": "npx ts-node"
    },
    "env": {
      "NODE_ENV": "development",
      "NODE_OPTIONS": "--max-old-space-size=4096"
    },
    "delay": 1000,
    "verbose": true
  },
  "dependencies": {
    "@montezuma/shared-config": "^1.0.0",
    "@montezuma/shared-logger": "^1.0.0",
    "@montezuma/shared-services": "^1.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.61.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.4-lts.1",
    "mysql2": "^3.15.2",
    "winston": "^3.18.3",
    "knex": "^3.2.0",
    "slugify": "^1.6.9",
    "fs-extra": "^11.3.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.7",
    "@types/node": "^22.13.10",
    "nodemon": "^3.1.10",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.8.2"
  },
  "author": "Peter Mumo",
  "license": "ISC",
  "engines": {
    "node": ">=24.0.0"
  }
}