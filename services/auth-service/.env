# auth-service Configuration
NODE_ENV=production
PORT=5001
SERVICE_NAME=auth-service
INTERNAL_SERVICE_SECRET=RestPointInternalSecret2024

GLOBAL_REFRESH_SECRET=RestPointRefreshSecret2024!SuperSecureInProduction
GLOBAL_JWT_SECRET=RestPointJWTSecret2024ChangeMe!SuperSecureInProduction
REFRESH_TOKEN_SECRET=RestPointRefreshSecret2024!SuperSecureInProduction
JWT_SECRET=RestPointJWTSecret2024ChangeMe!SuperSecureInProduction

# Database
# IMPORTANT: Use 127.0.0.1 instead of localhost to avoid MySQL socket authentication issues
# For Docker container, use restpoint_mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=restpoint_main
DB_USER=restpoint_user
DB_PASSWORD=RestPointUser2024

# MySQL Admin Credentials (for bootstrap script)
# IMPORTANT: Set this to your actual MySQL root password!
# If your root user has no password, leave it empty: DB_ADMIN_PASSWORD=
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=root  # CHANGE THIS to your MySQL root password!

# Redis Cache
REDIS_HOST=restpoint_redis
REDIS_PORT=6379
# REDIS_PASSWORD=RestPointRedis2024

# JWT/Security
JWT_SECRET=RestPointJWTSecret2024ChangeMe!SuperSecureInProduction

# Service-specific Configuration
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_HTTP_ONLY=true

# Service Discovery (Docker DNS)
AUTH_SERVICE_URL=http://auth-service:5001
TENANT_SERVICE_URL=http://tenant-service:5002
DECEASED_SERVICE_URL=http://deceased-service:5003
MARKETPLACE_SERVICE_URL=http://marketplace-service:5004
INVOICE_SERVICE_URL=http://invoice-service:5007
COFFIN_SERVICE_URL=http://coffin-service:5008
DOCUMENTS_SERVICE_URL=http://documents-service:5011
EDOCUMENTS_SERVICE_URL=http://edocuments-service:5014
ANALYTICS_SERVICE_URL=http://analytics-service:5012
CALENDAR_SERVICE_URL=http://calender-service:5015
MPESA_SERVICE_URL=http://mpesa-service:5005
NOTIFICATION_SERVICE_URL=http://notification-service:5010
SOCKETIO_SERVICE_URL=http://socketio-service:5018
VISITORS_SERVICE_URL=http://visitors-service:5009
BODYCHECKOUT_SERVICE_URL=http://bodycheckout-service:5013
PORTAL_SERVICE_URL=http://portal-service:5006
CHEMICAL_SERVICE_URL=http://chemical-service:5016
BILLING_SERVICE_URL=http://billing-service:5017
QRCODE_SERVICE_URL=http://qrcode-service:5021
API_GATEWAY_URL=http://api-gateway:5000
