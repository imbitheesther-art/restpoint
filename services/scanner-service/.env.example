# Scanner Service Configuration
SERVER_PORT=2024
SERVER_HOST=0.0.0.0
SERVER_ENV=development

# Storage Configuration
STORAGE_TYPE=local
STORAGE_UPLOAD_PATH=./uploads/scanned

# Scanner Configuration
SCANNER_AUTO_DETECT=true
SCANNER_DEFAULT_DPI=300
SCANNER_DEFAULT_FORMAT=pdf

# Database (if needed for document metadata)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=scanner_user
# DB_PASSWORD=scanner_pass
# DB_NAME=scanner_db

# Logging
LOG_LEVEL=info
LOG_FORMAT=json