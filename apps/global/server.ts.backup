/**
 * @file apps/global/index.ts
 * Central export hub for the global shared module.
 * All services import shared auth, middleware, db, and utilities from here.
 *
 * NOTE: Uses CommonJS require() internally so services using require('../global/index')
 * continue to work without modification during incremental migration.
 */

import type {
  UserPayload,
  UserRole,
  TenantRecord,
  TenantValidationResult,
  ApiResponse,
  LoginRequestDTO,
  LoginResponseDTO,
  RegisterRequestDTO,
  UserInfoDTO,
  UserRecord,
  RefreshTokenRecord,
  SessionRecord,
  PaginationParams,
} from './types/index';

import type {
  AppError,
  ValidationError,
  AuthenticationError,
  AuthorizationError,
  TenantIsolationError,
  NotFoundError,
  DatabaseError,
  ExternalServiceError,
} from './types/errors';

import type { AppConfig } from './config/env';
import type { TransactionContext } from './config/db';

// Re-export all types for consumers
export type {
  UserPayload,
  UserRole,
  TenantRecord,
  TenantValidationResult,
  ApiResponse,
  LoginRequestDTO,
  LoginResponseDTO,
  RegisterRequestDTO,
  UserInfoDTO,
  UserRecord,
  RefreshTokenRecord,
  SessionRecord,
  PaginationParams,
  AppError,
  ValidationError,
  AuthenticationError,
  AuthorizationError,
  TenantIsolationError,
  NotFoundError,
  DatabaseError,
  ExternalServiceError,
  AppConfig,
  TransactionContext,
};

// ============================================================
// RUNTIME IMPORTS (CommonJS for backward compat)
// ============================================================

const bcrypt = require('bcrypt') as typeof import('bcrypt');
const crypto = require('crypto') as typeof import('crypto');
const jwt = require('jsonwebtoken') as typeof import('jsonwebtoken');
const asyncHandler = require('express-async-handler') as typeof import('express-async-handler');
const express = require('express') as typeof import('express');
const helmet = require('helmet') as typeof import('helmet');
const cors = require('cors') as typeof import('cors');
const knex = require('knex') as typeof import('knex');
const winston = require('winston') as typeof import('winston');

// Internal modules
const authTokens = require('./auth/tokens') as {
  generateAccessToken: (payload: UserPayload, expiry?: string) => string;
  generateRefreshToken: (payload: UserPayload, expiry?: string) => string;
  verifyAccessToken: (token: string) => UserPayload | null;
  verifyRefreshToken: (token: string) => UserPayload | null;
  decodeToken: (token: string) => UserPayload | null;
  ACCESS_TOKEN_EXPIRY: string;
  REFRESH_TOKEN_EXPIRY: string;
};

const authCookies = require('./auth/cookies') as {
  setAccessTokenCookie: (res: import('express').Response, token: string) => void;
  setRefreshTokenCookie: (res: import('express').Response, token: string, opts?: object) => void;
  setCsrfSecretCookie: (res: import('express').Response, secret: string, opts?: object) => void;
  setUserInfoCookie: (res: import('express').Response, info: UserInfoDTO) => void;
  clearAuthCookies: (res: import('express').Response) => void;
  getUserFromCookies: (req: import('express').Request) => Partial<UserPayload> | null;
  getTokenFromRequest: (req: import('express').Request) => string | null;
  getSecureCookieOptions: () => object;
  getPublicCookieOptions: () => object;
};

const authCsrf = require('./auth/csrf') as {
  generateSecret: () => Promise<string>;
  generateToken: (secret: string) => string;
  verifyToken: (secret: string, token: string) => boolean;
  csrfProtection: import('express').RequestHandler;
};

const authMiddleware = require('./middlewares/AuthMiddleware') as {
  authenticate: import('express').RequestHandler;
  optionalAuth: import('express').RequestHandler;
  authorize: (...roles: UserRole[]) => import('express').RequestHandler;
  isAuthenticated: (req: import('express').Request) => boolean;
};

const { sanitizeMiddleware, sanitizeString, sanitizeObject, isValidUUID, isValidKenyanPhone, isPositiveAmount, safeInt } =
  require('./middlewares/sanitize') as {
    sanitizeMiddleware: import('express').RequestHandler;
    sanitizeString: (val: unknown) => unknown;
    sanitizeObject: (obj: unknown, depth?: number) => unknown;
    isValidUUID: (str: string) => boolean;
    isValidKenyanPhone: (phone: string) => boolean;
    isPositiveAmount: (val: unknown) => boolean;
    safeInt: (val: unknown, defaultVal?: number, min?: number, max?: number) => number;
  };

const db = require('./config/db') as {
  pool: import('mysql2/promise').Pool;
  initDB: () => Promise<void>;
  safeQuery: <T extends import('mysql2/promise').RowDataPacket>(sql: string, params?: unknown[]) => Promise<T[]>;
  safeQueryOne: <T extends import('mysql2/promise').RowDataPacket>(sql: string, params?: unknown[]) => Promise<T | null>;
  getConnection: () => Promise<import('mysql2/promise').PoolConnection>;
  transaction: <T>(callback: (ctx: TransactionContext) => Promise<T>) => Promise<T>;
  healthCheck: () => Promise<{ status: 'healthy' | 'unhealthy'; message: string }>;
  getPoolStatus: () => { totalConnections: number; freeConnections: number; waitingClients: number };
  closeDB: () => Promise<void>;
};

const redis = require('./config/redis') as {
  redis: import('ioredis').Redis | null;
  get: (key: string) => Promise<string | null>;
  set: (key: string, value: string, ttl?: number) => Promise<boolean>;
  del: (key: string) => Promise<boolean>;
  exists: (key: string) => Promise<number>;
  expire: (key: string, seconds: number) => Promise<boolean>;
  incr: (key: string) => Promise<number>;
  keys: (pattern: string) => Promise<string[]>;
};

const rateLimiter = require('./rateLimit/index') as {
  createRateLimiter: (opts: object) => import('express').RequestHandler;
  apiLimiter: import('express').RequestHandler;
  strictLimiter: import('express').RequestHandler;
  userLimiter: import('express').RequestHandler;
  adminLimiter: import('express').RequestHandler;
  endorsementLimiter: import('express').RequestHandler;
  walletLimiter: import('express').RequestHandler;
  publicLimiter: import('express').RequestHandler;
  searchLimiter: import('express').RequestHandler;
  uploadLimiter: import('express').RequestHandler;
  authLimiter: import('express').RequestHandler;
  createWhitelistAwareLimiter: (opts: object) => import('express').RequestHandler;
  applyLimiters: (...limiters: import('express').RequestHandler[]) => import('express').RequestHandler;
  skipIfWhitelisted: import('express').RequestHandler;
};

const logger = require('./logger/logger') as {
  info: (message: string, ...meta: unknown[]) => void;
  warn: (message: string, ...meta: unknown[]) => void;
  error: (message: string, ...meta: unknown[]) => void;
  debug: (message: string, ...meta: unknown[]) => void;
};

const { getKenyaTimeISO, getKenyaTimeFormatted } = require('./utils/timeStamps') as {
  getKenyaTimeISO: () => string;
  getKenyaTimeFormatted: () => string;
};

const { sendEmail } = require('./utils/emailHelper') as {
  sendEmail: (to: string, subject: string, html: string) => Promise<void>;
};

// ============================================================
// STARTUP GUARD: Enforce strong JWT secrets
// ============================================================

import { config } from './config/env';

// config import will throw EnvValidationError if required secrets are missing in production
// Weak secret detection is handled inside env.ts

// ============================================================
// SAFE REDIS WRAPPERS
// ============================================================

const safeRedisClient = redis?.redis ?? null;

const safeRedisGet = async (key: string): Promise<string | null> => {
  if (!safeRedisClient || safeRedisClient.status !== 'ready') return null;
  try { return await redis.get(key); }
  catch (err) { logger.error(`Redis get error: ${key}`, err); return null; }
};

const safeRedisSet = async (key: string, value: string, ttl?: number): Promise<boolean> => {
  if (!safeRedisClient || safeRedisClient.status !== 'ready') return false;
  try { await redis.set(key, value, ttl); return true; }
  catch (err) { logger.error(`Redis set error: ${key}`, err); return false; }
};

const safeRedisDel = async (key: string): Promise<boolean> => {
  if (!safeRedisClient || safeRedisClient.status !== 'ready') return false;
  try { await redis.del(key); return true; }
  catch (err) { logger.error(`Redis del error: ${key}`, err); return false; }
};

const safeRedisExists = async (key: string): Promise<boolean> => {
  if (!safeRedisClient) return false;
  try { return (await redis.exists(key)) > 0; }
  catch (err) { logger.error(`Redis exists error: ${key}`, err); return false; }
};

const safeRedisExpire = async (key: string, seconds: number): Promise<boolean> => {
  if (!safeRedisClient) return false;
  try { return await redis.expire(key, seconds); }
  catch (err) { logger.error(`Redis expire error: ${key}`, err); return false; }
};

const safeRedisIncr = async (key: string): Promise<number> => {
  if (!safeRedisClient) return 0;
  try { return await redis.incr(key); }
  catch (err) { logger.error(`Redis incr error: ${key}`, err); return 0; }
};

const safeRedisKeys = async (pattern: string): Promise<string[]> => {
  if (!safeRedisClient || safeRedisClient.status !== 'ready') return [];
  try { return await redis.keys(pattern); }
  catch (err) { logger.error(`Redis keys error: ${pattern}`, err); return []; }
};

// ============================================================
// COMMONJS EXPORTS (backward compat for all services)
// ============================================================

module.exports = {
  // --- Global Libraries ---
  bcrypt,
  crypto,
  jwt,
  asyncHandler,
  express,
  helmet,
  cors,
  knex,
  winston,
  config,

  // --- Auth Tokens ---
  generateAccessToken: authTokens.generateAccessToken,
  generateRefreshToken: authTokens.generateRefreshToken,
  verifyAccessToken: authTokens.verifyAccessToken,
  verifyRefreshToken: authTokens.verifyRefreshToken,
  decodeToken: authTokens.decodeToken,
  ACCESS_TOKEN_EXPIRY: authTokens.ACCESS_TOKEN_EXPIRY,
  REFRESH_TOKEN_EXPIRY: authTokens.REFRESH_TOKEN_EXPIRY,

  // --- Auth Cookies ---
  setAccessTokenCookie: authCookies.setAccessTokenCookie,
  setRefreshTokenCookie: authCookies.setRefreshTokenCookie,
  setCsrfSecretCookie: authCookies.setCsrfSecretCookie,
  setUserInfoCookie: authCookies.setUserInfoCookie,
  clearAuthCookies: authCookies.clearAuthCookies,
  getUserFromCookies: authCookies.getUserFromCookies,
  getTokenFromRequest: authCookies.getTokenFromRequest,
  getSecureCookieOptions: authCookies.getSecureCookieOptions,
  getPublicCookieOptions: authCookies.getPublicCookieOptions,

  // --- CSRF Protection ---
  generateCsrfSecret: authCsrf.generateSecret,
  generateCsrfToken: authCsrf.generateToken,
  verifyCsrfToken: authCsrf.verifyToken,
  csrfProtection: authCsrf.csrfProtection,

  // --- Auth Middleware ---
  authenticate: authMiddleware.authenticate,
  optionalAuth: authMiddleware.optionalAuth,
  authorize: authMiddleware.authorize,
  isAuthenticated: authMiddleware.isAuthenticated,

  // --- Rate Limiters ---
  createRateLimiter: rateLimiter.createRateLimiter,
  apiLimiter: rateLimiter.apiLimiter,
  strictLimiter: rateLimiter.strictLimiter,
  userLimiter: rateLimiter.userLimiter,
  adminLimiter: rateLimiter.adminLimiter,
  endorsementLimiter: rateLimiter.endorsementLimiter,
  walletLimiter: rateLimiter.walletLimiter,
  publicLimiter: rateLimiter.publicLimiter,
  searchLimiter: rateLimiter.searchLimiter,
  uploadLimiter: rateLimiter.uploadLimiter,
  authLimiter: rateLimiter.authLimiter,
  createWhitelistAwareLimiter: rateLimiter.createWhitelistAwareLimiter,
  applyLimiters: rateLimiter.applyLimiters,
  skipIfWhitelisted: rateLimiter.skipIfWhitelisted,

  // --- Database ---
  db: {
    pool: db.pool,
    initDB: db.initDB,
    safeQuery: db.safeQuery,
    safeQueryOne: db.safeQueryOne,
    getConnection: db.getConnection,
    transaction: db.transaction,
    healthCheck: db.healthCheck,
    getPoolStatus: db.getPoolStatus,
    closeDB: db.closeDB,
  },

  // --- Redis ---
  redis: {
    client: safeRedisClient,
    get: safeRedisGet,
    set: safeRedisSet,
    del: safeRedisDel,
    exists: safeRedisExists,
    expire: safeRedisExpire,
    incr: safeRedisIncr,
    keys: safeRedisKeys,
  },

  // --- Logger ---
  logger,

  // --- Utilities ---
  utils: {
    getKenyaTimeISO,
    getKenyaTimeFormatted,
    sendEmail,
  },

  // --- Input Sanitization ---
  sanitizeMiddleware,
  sanitizeString,
  sanitizeObject,
  isValidUUID,
  isValidKenyanPhone,
  isPositiveAmount,
  safeInt,
};
