// Fixed version of the function
export const billingHealthCheck = async (req: any, res: any, next: any): Promise<void> => {
  try {
    res.status(200).json({
      status: 'healthy',
      service: 'billing-scheduler',
      timestamp: new Date().toISOString()
    });
  } catch (error) {
    next(error);
  }
};
